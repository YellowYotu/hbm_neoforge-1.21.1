{
  "multipart": [
    {
      "apply": {
        "model": "hbm_neoforge:block/reinforced_glass_pane_post"
      }
    },
    {
      "when": {
        "north": "true"
      },
      "apply": {
        "model": "hbm_neoforge:block/reinforced_glass_pane_side"
      }
    },
    {
      "when": {
        "east": "true"
      },
      "apply": {
        "model": "hbm_neoforge:block/reinforced_glass_pane_side",
        "y": 90
      }
    },
    {
      "when": {
        "south": "true"
      },
      "apply": {
        "model": "hbm_neoforge:block/reinforced_glass_pane_side_alt"
      }
    },
    {
      "when": {
        "west": "true"
      },
      "apply": {
        "model": "hbm_neoforge:block/reinforced_glass_pane_side_alt",
        "y": 90
      }
    }
  ]
}